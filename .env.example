# Elephant runtime onboarding example.
# Runtime only. Benchmark configuration lives under `bench/`:
# - checked-in contract profiles in `bench/*/profiles/*.toml`
# - optional execution overlays in TOML
# - benchmark secrets in `bench/secrets.example.env`
#
# For the full runtime env reference, see `docs/runtime-config.md`.

# Server
DATABASE_URL=postgres://elephant:elephant@localhost:5434/elephant
LISTEN_ADDR=0.0.0.0:3001
# SERVER_AUTO_CONSOLIDATION=1
# SERVER_AUTO_CONSOLIDATION_MIN_FACTS=32
# SERVER_AUTO_CONSOLIDATION_COOLDOWN_SECS=30
# SERVER_AUTO_CONSOLIDATION_MERGE_OPINIONS=0

# Logging
# RUST_LOG=info
# LOG_FORMAT=json

# LLM provider
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_VERTEX_PROJECT=your-gcp-project-id
# LLM_VERTEX_LOCATION=global

# Model stack
# LLM_MODEL=claude-sonnet-4-6
RETAIN_LLM_MODEL=claude-haiku-4-5
REFLECT_LLM_MODEL=claude-sonnet-4-6
REFLECT_ENABLE_SOURCE_LOOKUP=1

# Embeddings (recommended local ONNX path)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_PATH=./models/bge-small-en-v1.5
ORT_DYLIB_PATH=./lib/onnxruntime-linux-x64-1.23.0/lib/libonnxruntime.so.1.23.0

# Alternative: OpenAI embeddings
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_API_MODEL=text-embedding-3-small
# EMBEDDING_API_DIMS=1536

# Reranker (recommended local ONNX path)
RERANKER_PROVIDER=local
RERANKER_MODEL_PATH=./models/ms-marco-MiniLM-L-6-v2

# Alternatives:
# RERANKER_PROVIDER=none
# RERANKER_PROVIDER=api
# RERANKER_API_KEY=...
# RERANKER_API_URL=https://api.cohere.ai/v1
# RERANKER_API_MODEL=rerank-english-v3.0
