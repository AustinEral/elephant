# Server
DATABASE_URL=postgres://elephant:elephant@localhost:5434/elephant
LISTEN_ADDR=0.0.0.0:3001
# SERVER_AUTO_CONSOLIDATION=1                 # default on for the HTTP/MCP server
# SERVER_AUTO_CONSOLIDATION_MIN_FACTS=32     # minimum unconsolidated world/experience facts before scheduling
# SERVER_AUTO_CONSOLIDATION_COOLDOWN_SECS=30 # minimum delay between consolidation attempts per bank
# SERVER_AUTO_CONSOLIDATION_MERGE_OPINIONS=0 # optionally run opinion merge after consolidation

# LLM (required)
LLM_PROVIDER=anthropic                 # or openai or gemini or vertex
LLM_API_KEY=sk-ant-...
# LLM_VERTEX_PROJECT=your-gcp-project-id  # required when LLM_PROVIDER=vertex
# LLM_VERTEX_LOCATION=global              # optional when LLM_PROVIDER=vertex

# Model config — set LLM_MODEL as a default, or set both tier overrides.
# LLM_MODEL=claude-sonnet-4-6            # default for all operations
RETAIN_LLM_MODEL=claude-haiku-4-5        # fast/cheap for extraction
REFLECT_LLM_MODEL=claude-sonnet-4-6      # smart for synthesis
REFLECT_ENABLE_SOURCE_LOOKUP=1          # default on; set to 0 for lookup-free reflect ablations
# LLM_BASE_URL=https://api.together.xyz/v1  # for OpenAI-compatible providers, Gemini proxies, or advanced Vertex overrides

# Embeddings — local ONNX (recommended)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_PATH=./models/bge-small-en-v1.5
ORT_DYLIB_PATH=./lib/onnxruntime-linux-x64-1.23.0/lib/libonnxruntime.so.1.23.0

# Embeddings — OpenAI API (alternative)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_API_MODEL=text-embedding-3-small
# EMBEDDING_API_DIMS=1536

# Reranker — local ONNX cross-encoder (recommended, needs model download)
RERANKER_PROVIDER=local
RERANKER_MODEL_PATH=./models/ms-marco-MiniLM-L-6-v2

# Reranker — disabled (skip reranking)
# RERANKER_PROVIDER=none

# Reranker — API (alternative)
# RERANKER_PROVIDER=api
# RERANKER_API_KEY=...
# RERANKER_API_URL=https://api.cohere.ai/v1
# RERANKER_API_MODEL=rerank-english-v3.0

# Retain dedup — skip inserting facts with cosine similarity >= threshold to existing facts
# DEDUP_THRESHOLD=0.95  # default 0.95, set to 'none' to disable

# LLM request timeout (default: 600s)
# LLM_TIMEOUT_SECS=600

# Reasoning effort overrides (optional, per stage)
# Supported values: none, minimal, low, medium, high, xhigh
# RETAIN_EXTRACT_REASONING_EFFORT=none
# RETAIN_RESOLVE_REASONING_EFFORT=none
# RETAIN_GRAPH_REASONING_EFFORT=none
# REFLECT_REASONING_EFFORT=high      # useful OpenAI gpt-5.4-mini tuning for stronger tool use; higher cost/latency
# CONSOLIDATE_REASONING_EFFORT=none
# OPINION_MERGE_REASONING_EFFORT=none

# Requested stage temperatures (optional, per stage)
# These preserve current defaults unless overridden, but provider/model support varies.
# Explicit unsupported overrides fail fast during runtime construction.
# For OpenAI GPT-5 reasoning models, custom temperature may be unsupported and ignored by the adapter.
# RETAIN_EXTRACT_TEMPERATURE=0.1
# RETAIN_RESOLVE_TEMPERATURE=0.0
# RETAIN_GRAPH_TEMPERATURE=0.0
# REFLECT_TEMPERATURE=0.3
# CONSOLIDATE_TEMPERATURE=0.3
# OPINION_MERGE_TEMPERATURE=0.3

# Benchmark determinism preflight (optional)
# best_effort: require a best-effort low-variance setup
# strong: require a strong determinism contract
# BENCH_DETERMINISM_REQUIREMENT=best_effort

# Prompt caching (optional, disabled by default)
# LLM_PROMPT_CACHE_ENABLED=1
# OPENAI_PROMPT_CACHE_KEY=elephant:reflect
# OPENAI_PROMPT_CACHE_RETENTION=in_memory   # or 24h
# ANTHROPIC_PROMPT_CACHE_TTL=5m            # or 1h
# Gemini uses native/implicit caching automatically when supported; no extra envs are required.

# Logging (default: info)
# RUST_LOG=info                                          # default
# RUST_LOG=elephant::retain=debug,elephant::reflect=debug  # verbose pipelines
# LOG_FORMAT=json                                        # json for machine-readable

# Benchmark judge (optional — falls back to LLM_* vars)
# JUDGE_PROVIDER=anthropic
# JUDGE_API_KEY=sk-ant-...
# JUDGE_MODEL=your-judge-model-here
# JUDGE_VERTEX_PROJECT=your-gcp-project-id
# JUDGE_VERTEX_LOCATION=global
# JUDGE_BASE_URL=https://api.openai.com/v1
