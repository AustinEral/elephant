# Server
DATABASE_URL=postgres://elephant:elephant@localhost:5433/elephant
LISTEN_ADDR=0.0.0.0:3001

# LLM
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514

# Local embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_PATH=./models/bge-small-en-v1.5
ORT_DYLIB_PATH=./lib/onnxruntime-linux-x64-1.23.0/lib/libonnxruntime.so.1.23.0

# API embeddings (OpenAI-compatible — works with OpenAI, Together, Voyage, etc.)
EMBEDDING_API_KEY=sk-...
EMBEDDING_API_MODEL=text-embedding-3-small
EMBEDDING_API_DIMS=1536
